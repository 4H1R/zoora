# Core
PORT=8080
DATABASE_URL=postgres://dev:dev@localhost:5432/zoora?sslmode=disable
REDIS_URL=redis://localhost:6379
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=private
S3_PUBLIC_BUCKET=public
S3_ACCESS_KEY=dev
S3_SECRET_KEY=dev
S3_REGION=us-east-1
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
ENVIRONMENT=development
# Comma-separated allow-list of browser origins. Defaults to "*" for local dev.
# In production set an explicit list (e.g. https://*.zoora.ir) so credentialed
# CORS stays enabled; a bare "*" disables Access-Control-Allow-Credentials.
CORS_ALLOWED_ORIGINS=*

# Billing (Zarinpal) + invoice issuer
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_BASE_URL=http://localhost:5173
# Tenant link template — "{slug}" is substituted per org.
APP_URL_TEMPLATE=http://{slug}.localhost:5173
INVOICE_ISSUER_NAME=Zoora
INVOICE_ISSUER_ECONOMIC_ID=
INVOICE_ISSUER_ADDRESS=
INVOICE_ISSUER_PHONE=

# Notification connectors (empty disables the channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_PROXY_URL=
BALE_BOT_TOKEN=
BALE_BOT_USERNAME=
BALE_PROXY_URL=
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=
FCM_CREDENTIALS_FILE=
