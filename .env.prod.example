# Edge / domains — subdomains used: app., api., livekit., s3.
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# App
ENVIRONMENT=production
PORT=8080
# Comma-separated allow-list of browser origins. In production set an explicit
# list (e.g. https://*.example.com, matching your tenant subdomains) so that
# credentialed CORS stays enabled. A bare "*" disables Access-Control-Allow-
# Credentials, because a credentialed wildcard is insecure (and browsers reject it).
CORS_ALLOWED_ORIGINS=https://*.example.com
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRY=24h

# Postgres
DB_USERNAME=zoora
DB_PASSWORD=CHANGE_ME
DB_DATABASE=zoora
DATABASE_URL=postgres://zoora:CHANGE_ME@pgsql:5432/zoora?sslmode=disable
# Optional read replica + per-process pool sizing.
# DATABASE_REPLICA_URL=postgres://zoora:CHANGE_ME@pgsql-replica:5432/zoora?sslmode=disable
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=10
# DB_CONN_MAX_LIFETIME=5m
# DB_CONN_MAX_IDLE_TIME=1m

# Redis
REDIS_URL=redis://redis:6379
# Optional per-role Redis (fall back to REDIS_URL when unset).
# REDIS_QUEUE_URL=redis://redis-queue:6379
# REDIS_PUBSUB_URL=redis://redis-pubsub:6379
# REDIS_CACHE_URL=redis://redis-cache:6379

# LiveKit — must match deploy/livekit.yaml webhook.api_key.
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_PUBLIC_URL=wss://livekit.example.com
LIVEKIT_API_KEY=CHANGE_ME_KEY
LIVEKIT_API_SECRET=CHANGE_ME_SECRET
# LIVE_ROOM_HOST_GRACE_PERIOD=15m

# S3 / RustFS
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=private
S3_PUBLIC_BUCKET=public
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=us-east-1

# Frontend build arg — unused at runtime; frontend is baked from DOMAIN.
VITE_API_URL=https://api.example.com

# Billing (Zarinpal) + invoice issuer
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=false
ZARINPAL_CALLBACK_BASE_URL=https://app.example.com
INVOICE_ISSUER_NAME=Zoora
INVOICE_ISSUER_ECONOMIC_ID=
INVOICE_ISSUER_ADDRESS=
INVOICE_ISSUER_PHONE=

# Notification connectors (empty disables the channel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_PROXY_URL=
BALE_BOT_TOKEN=
BALE_BOT_USERNAME=
BALE_PROXY_URL=
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=
FCM_CREDENTIALS_FILE=

# Error monitoring (Sentry) — fully optional; empty disables it entirely.
# Set SENTRY_DSN to enable backend reporting. SENTRY_TRACES_SAMPLE_RATE (0.0–1.0)
# also enables performance tracing; SENTRY_RELEASE tags events with a version.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_RELEASE=
# Frontend (baked at build time): VITE_SENTRY_DSN enables browser reporting.
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
# VITE_SENTRY_ENVIRONMENT=production
