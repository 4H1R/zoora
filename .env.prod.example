# ── Edge / domains ──────────────────────────────────────────────
# Apex domain. Subdomains used: app., api., livekit., s3.
DOMAIN=example.com
# Email for Let's Encrypt registration.
ACME_EMAIL=admin@example.com

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8080
# Browser origins allowed to call the API and open the WS. Multi-tenant: each
# org is served from its own <org>.example.com host, so use a subdomain wildcard
# (single "*"). Comma-separate to add more (e.g. an apex or marketing origin).
CORS_ALLOWED_ORIGINS=https://*.example.com
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRY=24h

# ── Postgres (self-hosted container) ────────────────────────────
DB_USERNAME=zoora
DB_PASSWORD=CHANGE_ME
DB_DATABASE=zoora
# Internal connection string used by api/worker/migrate.
DATABASE_URL=postgres://zoora:CHANGE_ME@pgsql:5432/zoora?sslmode=disable
# Optional read replica. When set, reads route here via gorm dbresolver and
# writes stay on the primary. Empty = everything hits the primary.
# DATABASE_REPLICA_URL=postgres://zoora:CHANGE_ME@pgsql-replica:5432/zoora?sslmode=disable
# Connection-pool sizing PER PROCESS (api and worker each open their own pool).
# Size Postgres max_connections for at least (pods * DB_MAX_OPEN_CONNS) * 2.
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=10
# DB_CONN_MAX_LIFETIME=5m
# DB_CONN_MAX_IDLE_TIME=1m

# ── Redis (self-hosted container) ───────────────────────────────
REDIS_URL=redis://redis:6379
# Optional per-role Redis URLs. Each falls back to REDIS_URL when unset, so one
# instance is the default; point these at separate instances to isolate the
# queue / WebSocket pub-sub / cache workloads as traffic grows.
# REDIS_QUEUE_URL=redis://redis-queue:6379
# REDIS_PUBSUB_URL=redis://redis-pubsub:6379
# REDIS_CACHE_URL=redis://redis-cache:6379

# ── LiveKit (self-hosted container) ─────────────────────────────
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_PUBLIC_URL=wss://livekit.example.com
LIVEKIT_API_KEY=CHANGE_ME_KEY
LIVEKIT_API_SECRET=CHANGE_ME_SECRET
# Grace window before a host-less live room auto-closes. Optional; default 15m.
# Must match deploy/livekit.yaml webhook.api_key == LIVEKIT_API_KEY above.
LIVE_ROOM_HOST_GRACE_PERIOD=15m

# ── S3 / RustFS (self-hosted container) ─────────────────────────
# Public endpoint — presigned URLs are generated against this host.
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=private
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=us-east-1

# Frontend tenant config is baked from DOMAIN at build time (see
# docker-compose.prod.yml frontend.build.args). VITE_API_URL is hardcoded to
# /api/v1 (same-origin) in frontend/Dockerfile — no env var needed.
