<!doctype html>
<html lang="fa" dir="rtl">
<head>
<meta charset="utf-8">
<style>
  @font-face { font-family: "Vazirmatn"; src: local("Vazirmatn"); }
  * { font-family: "Vazirmatn", sans-serif; box-sizing: border-box; }
  body { margin: 0; padding: 32px; color: #1a1a1a; }
  .head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #333; padding-bottom: 16px; }
  .issuer h1 { margin: 0; font-size: 20px; }
  .issuer p { margin: 2px 0; font-size: 12px; color: #555; }
  .meta { text-align: left; font-size: 13px; }
  .status { display: inline-block; padding: 4px 12px; border-radius: 6px; font-weight: bold; }
  .status.paid { background: #e6f7ea; color: #1a7f37; }
  .status.pending { background: #fff4e5; color: #b26a00; }
  table { width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 13px; }
  th, td { border: 1px solid #ddd; padding: 8px 10px; text-align: right; }
  th { background: #f5f5f5; }
  .totals { margin-top: 16px; width: 40%; margin-inline-start: auto; font-size: 13px; }
  .totals td { border: none; padding: 4px 8px; }
  .totals .grand { font-weight: bold; font-size: 15px; border-top: 2px solid #333; }
  .foot { margin-top: 40px; font-size: 11px; color: #888; text-align: center; }
</style>
</head>
<body>
  <div class="head">
    <div class="issuer">
      <h1>{{ .IssuerName }}</h1>
      {{ if .IssuerEconomicID }}<p>کد اقتصادی: {{ .IssuerEconomicID }}</p>{{ end }}
      {{ if .IssuerAddress }}<p>{{ .IssuerAddress }}</p>{{ end }}
      {{ if .IssuerPhone }}<p>تلفن: {{ .IssuerPhone }}</p>{{ end }}
    </div>
    <div class="meta">
      <div>فاکتور شماره: <strong>{{ .Number }}</strong></div>
      <div>تاریخ: {{ .IssuedAtFa }}</div>
      <div>مشتری: {{ .OrgName }}</div>
      <div class="status {{ .StatusClass }}">{{ .StatusFa }}</div>
    </div>
  </div>

  <table>
    <thead>
      <tr><th>شرح</th><th>تعداد</th><th>قیمت واحد (تومان)</th><th>مبلغ (تومان)</th></tr>
    </thead>
    <tbody>
      {{ range .Items }}
      <tr>
        <td>{{ .Description }}</td>
        <td>{{ .QuantityFa }}</td>
        <td>{{ .UnitAmountFa }}</td>
        <td>{{ .AmountFa }}</td>
      </tr>
      {{ end }}
    </tbody>
  </table>

  <table class="totals">
    <tr><td>جمع کل</td><td>{{ .SubtotalFa }} تومان</td></tr>
    {{ if .HasTax }}<tr><td>مالیات ({{ .TaxPercentFa }}٪)</td><td>{{ .TaxAmountFa }} تومان</td></tr>{{ end }}
    <tr class="grand"><td>مبلغ قابل پرداخت</td><td>{{ .TotalFa }} تومان</td></tr>
  </table>

  {{ if .RefID }}<p style="margin-top:24px;font-size:12px;">کد پیگیری پرداخت: {{ .RefIDFa }} — درگاه: {{ .GatewayFa }}</p>{{ end }}
  {{ if .PaidAtFa }}<p style="font-size:12px;">تاریخ پرداخت: {{ .PaidAtFa }}</p>{{ end }}

  <div class="foot">این فاکتور توسط سامانه {{ .IssuerName }} صادر شده است.</div>
</body>
</html>
