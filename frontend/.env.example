VITE_API_URL=/api/v1
VITE_WS_URL=/api/v1/ws
VITE_BASE_DOMAIN=localhost
VITE_ADMIN_SUBDOMAIN=admin

# --- Firebase Cloud Messaging (web push; all five required to enable push) ---
# From Firebase console > Project settings > General > Your apps (web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Cloud Messaging > Web configuration > Web Push certificates (key pair).
VITE_FIREBASE_VAPID_KEY=
