(zoora_tls) {
	tls /etc/caddy/certs/zoora/fullchain.pem /etc/caddy/certs/zoora/privatekey.pem
}

dev.m65tech.com {
	encode zstd gzip
	reverse_proxy localhost:8000
}

zoora.ir {
	import zoora_tls
	redir https://www.zoora.ir{uri} permanent
}

www.zoora.ir {
	import zoora_tls
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:8080
	}

	handle {
		reverse_proxy 127.0.0.1:8081
	}
}

s3.zoora.ir {
	import zoora_tls

	# Browser uploads/downloads via presigned URLs from the SPA. RustFS S3-API
	# CORS is unreliable, so terminate CORS here: answer preflight directly and
	# normalize the origin header on real responses (strip upstream to avoid a
	# duplicate Access-Control-Allow-Origin).
	@preflight method OPTIONS
	handle @preflight {
		header Access-Control-Allow-Origin "https://app.zoora.ir"
		header Access-Control-Allow-Methods "GET, PUT, POST, DELETE, HEAD"
		header Access-Control-Allow-Headers "*"
		header Access-Control-Max-Age "3600"
		respond 204
	}

	handle {
		reverse_proxy 127.0.0.1:9000 {
			header_down -Access-Control-Allow-Origin
			header_down +Access-Control-Allow-Origin "https://app.zoora.ir"
			header_down +Access-Control-Expose-Headers "ETag"
		}
	}
}

console.zoora.ir {
	import zoora_tls
	reverse_proxy 127.0.0.1:9001
}

livekit.zoora.ir {
	import zoora_tls
	reverse_proxy 127.0.0.1:7880
}

*.zoora.ir {
	import zoora_tls

	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:8080
	}

	handle {
		reverse_proxy 127.0.0.1:8081
	}
}
