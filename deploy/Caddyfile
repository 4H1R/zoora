(zoora_tls) {
	tls /etc/caddy/certs/zoora/fullchain.pem /etc/caddy/certs/zoora/privatekey.pem
}

(strip_headers) {
	header -Server
	header -Via
	header -X-Powered-By
}

dev.m65tech.com {
	import strip_headers
	encode zstd gzip
	reverse_proxy localhost:8000
}

zoora.ir {
	import zoora_tls
	import strip_headers
	redir https://www.zoora.ir{uri} permanent
}

www.zoora.ir {
	import zoora_tls
	import strip_headers
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:8080
	}

	handle {
		reverse_proxy 127.0.0.1:8081
	}
}

s3.zoora.ir {
	import zoora_tls
	import strip_headers

	@cors header_regexp origin Origin ^https://([a-z0-9-]+\.)?zoora\.ir$

	@preflight method OPTIONS
	handle @preflight {
		header @cors Access-Control-Allow-Origin "{re.origin.0}"
		header Access-Control-Allow-Methods "GET, PUT, POST, DELETE, HEAD"
		header Access-Control-Allow-Headers "*"
		header Access-Control-Max-Age "3600"
		header Vary "Origin"
		respond 204
	}

	handle {
		reverse_proxy 127.0.0.1:9000 {
			header_down -Access-Control-Allow-Origin
			header_down Access-Control-Expose-Headers "ETag"
		}
		header @cors Access-Control-Allow-Origin "{re.origin.0}"
		header @cors +Vary "Origin"
	}
}

console.zoora.ir {
	import zoora_tls
	import strip_headers
	reverse_proxy 127.0.0.1:9001
}

livekit.zoora.ir {
	import zoora_tls
	import strip_headers
	reverse_proxy 127.0.0.1:7880
}

*.zoora.ir {
	import zoora_tls
	import strip_headers

	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:8080
	}

	handle {
		reverse_proxy 127.0.0.1:8081
	}
}
